datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum CharacterStatus {
  DRAFT
  REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum MessageRole {
  user
  assistant
  system
}

enum ReportTargetType {
  CHARACTER
  MESSAGE
  GENERATION_OUTPUT
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  REJECTED
}

enum AdminAuditAction {
  REPORT_STATUS_UPDATE
  HIDE_CHARACTER
  ARCHIVE_MESSAGE
  HIDE_GENERATION_OUTPUT
  TOKEN_ADJUSTMENT
}

enum TokenTransactionType {
  CHAT_USAGE
  IMAGE_GENERATION
  ADMIN_ADJUSTMENT
  PROMOTION
  PURCHASE
  REFUND
  DAILY_LOGIN
  ACHIEVEMENT
  PENALTY
  EXPIRY
}

enum GenerationJobStatus {
  BLOCKED
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum GenerationOutputKind {
  IMAGE
  VIDEO
}

enum GenerationOutputVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

model User {
  id               String    @id @db.Uuid
  email            String    @unique
  username         String?   @unique
  role             Role      @default(USER)
  tokenBalance     Int       @default(1000)
  contentMaxRating String    @default("teen_romance")
  adultVerifiedAt  DateTime?
  persona          String?   @db.Text
  personaUpdatedAt DateTime?

  characters        Character[]
  chats             Chat[]
  favorites         Favorite[]
  usages            Usage[]
  reports           Report[]
  adminAuditLogs    AdminAuditLog[]
  tokenTransactions TokenTransaction[]
  creatorDraft      CreatorDraft?
  generationJobs    GenerationJob[]
  generationOutputs GenerationOutput[]
  providerKeys      UserProviderKey[]
  securityAuditLogs UserSecurityAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Character {
  id        String  @id @default(uuid()) @db.Uuid
  sourceKey String? @unique

  name          String
  avatarUrl     String?
  coverUrl      String?
  tagline       String?
  description   String? @db.Text
  biography     String? @db.Text
  scenario      String? @db.Text
  greeting      String? @db.Text
  exampleDialog String? @db.Text

  systemPrompt    String  @db.Text
  compactPrompt   String? @db.Text
  characterAnchor String? @db.Text
  constraints     String? @db.Text
  promptVersion   Int     @default(1)

  status       CharacterStatus @default(DRAFT)
  visibility   Visibility      @default(PRIVATE)
  qualityScore Int             @default(0)
  qualityNotes Json?
  publishedAt  DateTime?

  viewCount Int @default(0)
  chatCount Int @default(0)

  creatorId String @db.Uuid
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  chats       Chat[]
  favoritedBy Favorite[]
  tags        CharacterTag[]
  loreEntries LoreEntry[]
  reports     Report[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, visibility, deletedAt, createdAt(sort: Desc)])
  @@index([status, visibility, deletedAt, chatCount(sort: Desc)])
  @@index([creatorId])
}

model Tag {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  characters CharacterTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CharacterTag {
  characterId String @db.Uuid
  tagId       String @db.Uuid

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([characterId, tagId])
  @@index([tagId])
}

model Chat {
  id      String  @id @default(uuid()) @db.Uuid
  title   String?
  summary String? @db.Text

  memory            Json?
  sceneState        Json?
  relationshipState Json?

  isArchived Boolean @default(false)

  userId      String @db.Uuid
  characterId String @db.Uuid

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  messages  Message[]

  lastMessageAt DateTime  @default(now())
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, isArchived, lastMessageAt(sort: Desc)])
  @@index([characterId, lastMessageAt(sort: Desc)])
  @@index([deletedAt])
}

model Message {
  id      String      @id @default(cuid())
  role    MessageRole
  content String      @db.Text

  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  tokenUsed        Int      @default(0)
  modelUsed        String?
  cost             Decimal? @db.Decimal(10, 6)
  metadata         Json?
  isEdited         Boolean  @default(false)

  chatId  String   @db.Uuid
  chat    Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  reports Report[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([chatId, createdAt(sort: Asc)])
  @@index([chatId, deletedAt, createdAt(sort: Desc), id(sort: Desc)], map: "Message_chatId_deletedAt_createdAt_id_idx")
  @@index([deletedAt])
}

model LoreEntry {
  id          String @id @default(uuid()) @db.Uuid
  characterId String @db.Uuid

  keyword        String
  aliases        String[]
  content        String   @db.Text
  priority       Int      @default(0)
  hierarchyLevel Int      @default(0)
  parentLoreId   String?  @db.Uuid

  character  Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  parentLore LoreEntry?  @relation("LoreHierarchy", fields: [parentLoreId], references: [id])
  children   LoreEntry[] @relation("LoreHierarchy")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([characterId, keyword])
  @@index([characterId, priority])
  @@index([parentLoreId])
  @@index([deletedAt])
}

model Favorite {
  id          String @id @default(uuid()) @db.Uuid
  userId      String @db.Uuid
  characterId String @db.Uuid

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, characterId])
  @@index([userId])
  @@index([characterId])
}

model Usage {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  tokens    Int
  cost      Decimal? @db.Decimal(10, 6)
  modelName String?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenTransaction TokenTransaction?

  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model TokenTransaction {
  id           String               @id @default(uuid()) @db.Uuid
  userId       String               @db.Uuid
  usageId      String?              @unique @db.Uuid
  type         TokenTransactionType
  amount       Int
  balanceAfter Int
  reason       String?
  metadata     Json?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage Usage? @relation(fields: [usageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

model UserProviderKey {
  id            String  @id @default(uuid()) @db.Uuid
  userId        String  @db.Uuid
  provider      String
  keyCiphertext String  @db.Text
  keyHint       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model UserSecurityAuditLog {
  id         String  @id @default(uuid()) @db.Uuid
  userId     String  @db.Uuid
  action     String
  targetType String
  targetId   String?
  metadata   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

model Report {
  id         String           @id @default(uuid()) @db.Uuid
  targetType ReportTargetType
  reason     String
  details    String?          @db.Text
  status     ReportStatus     @default(PENDING)
  metadata   Json?

  reporterId         String  @db.Uuid
  characterId        String? @db.Uuid
  messageId          String?
  generationOutputId String? @db.Uuid

  reporter         User              @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  character        Character?        @relation(fields: [characterId], references: [id], onDelete: SetNull)
  message          Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)
  generationOutput GenerationOutput? @relation(fields: [generationOutputId], references: [id], onDelete: SetNull)

  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([targetType, createdAt(sort: Desc)])
  @@index([reporterId, createdAt(sort: Desc)])
  @@index([characterId])
  @@index([messageId])
  @@index([generationOutputId])
}

model AdminAuditLog {
  id         String           @id @default(uuid()) @db.Uuid
  action     AdminAuditAction
  targetType String
  targetId   String
  metadata   Json?

  actorUserId String? @db.Uuid
  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([action, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@index([actorUserId, createdAt(sort: Desc)])
}

model CreatorDraft {
  userId String @id @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  payload Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GenerationJob {
  id         String              @id @default(uuid()) @db.Uuid
  userId     String              @db.Uuid
  templateId String
  mode       String
  status     GenerationJobStatus @default(BLOCKED)
  source     String              @default("local-safe-preflight")

  prompt      String   @db.Text
  imageInputs String[]
  videoInputs String[]

  costTokens     Int     @default(0)
  debitStatus    String  @default("not_charged")
  failureCode    String?
  failureMessage String? @db.Text
  metadata       Json?

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  outputs GenerationOutput[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([templateId, createdAt(sort: Desc)])
}

model GenerationOutput {
  id         String                     @id @default(uuid()) @db.Uuid
  jobId      String                     @db.Uuid
  userId     String                     @db.Uuid
  kind       GenerationOutputKind
  url        String?
  storageKey String?
  visibility GenerationOutputVisibility @default(PRIVATE)
  isFavorite Boolean                    @default(false)
  metadata   Json?

  job     GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isFavorite, createdAt(sort: Desc)])
  @@index([visibility, createdAt(sort: Desc)])
  @@index([jobId])
}
