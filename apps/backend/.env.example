# Backend Environment Variables Template
# Copy this file to .env for local development.
# The default DATABASE_URL matches the root docker-compose.yml Postgres service.

# Database
DATABASE_URL="postgresql://admin:password123@localhost:5432/maprang_local?schema=public"

# Server
PORT=3000
NODE_ENV=development

# API Keys (optional for local when CHAT_PROVIDER=local; required for live provider smoke)
CHAT_PROVIDER="local"
LOCAL_CHAT_PROVIDER=1
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-2.0-flash-001"
IMAGE_GENERATION_API_KEY=""
IMAGE_GENERATION_MODEL="gpt-image-1.5"

# Cors
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Admin (local only; use a long random value in staging/production)
ADMIN_API_KEY="dev-admin-key-change-me"

# Supabase Auth / Storage (production uses signed avatars bucket)
SUPABASE_URL=""
SUPABASE_JWT_ISSUER=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="avatars"
SUPABASE_STORAGE_ACCESS="signed"
SUPABASE_SIGNED_URL_EXPIRES_IN=3600

# Token Economy
DAILY_LOGIN_REWARD=50
TOKEN_EXPIRY_DAYS=30
MIN_TOKEN_BALANCE_FOR_CHAT=1

# Model budget
MODEL_INPUT_COST_PER_1M=0
MODEL_OUTPUT_COST_PER_1M=0
MODEL_TEMPERATURE=0.85
MODEL_MAX_OUTPUT_TOKENS=1600
MODEL_MIN_ROLEPLAY_REPLY_CHARS=420
PROMPT_BUDGET_TOKENS=6000
PROMPT_HISTORY_MAX_MESSAGES=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
