NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Database
DATABASE_URL=postgresql://admin:password123@localhost:5432/maprang_local

# OpenRouter
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
MODEL_INPUT_COST_PER_1M=0.1
MODEL_OUTPUT_COST_PER_1M=0.4
MODEL_TEMPERATURE=0.85
MODEL_MAX_OUTPUT_TOKENS=900
MAX_INPUT_CHARS=4000
MIN_TOKEN_BALANCE_FOR_CHAT=1

# Optional image generation for Creator Studio.
# If omitted, Creator Studio uses a clearly labeled placeholder image while AI still drafts text content.
IMAGE_GENERATION_API_KEY=replace-with-openai-image-key
IMAGE_GENERATION_MODEL=gpt-image-1.5
IMAGE_GENERATION_SIZE=1024x1536
IMAGE_GENERATION_QUALITY=medium
IMAGE_GENERATION_OUTPUT_FORMAT=webp
IMAGE_GENERATION_OUTPUT_COMPRESSION=85

# Security
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ADMIN_API_KEY=replace-with-long-random-admin-key

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
# Optional. Defaults to SUPABASE_URL/auth/v1 when omitted.
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
# Optional. Used to validate HS256/shared-secret Supabase access tokens via Auth server.
SUPABASE_ANON_KEY=replace-with-anon-key

# Supabase Storage
# Optional for local dev. When both values are set with SUPABASE_URL, avatar uploads use Supabase Storage.
STORAGE_PROVIDER=local
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=avatars
SUPABASE_STORAGE_ACCESS=signed
SUPABASE_SIGNED_URL_EXPIRES_IN=3600
