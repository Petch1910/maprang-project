NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# ฐานข้อมูล
DATABASE_URL=postgresql://admin:password123@localhost:5432/maprang_local

# OpenRouter
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
MODEL_INPUT_COST_PER_1M=0.1
MODEL_OUTPUT_COST_PER_1M=0.4
MODEL_TEMPERATURE=0.85
MODEL_MAX_OUTPUT_TOKENS=1600
MODEL_MIN_ROLEPLAY_REPLY_CHARS=420
PROMPT_BUDGET_TOKENS=6000
PROMPT_HISTORY_MAX_MESSAGES=12
CHAT_PROVIDER_RETRY_ATTEMPTS=2
CHAT_PROVIDER_RETRY_DELAY_MS=350
# ตั้งเป็น 1 เฉพาะหลัง `bun run smoke:chat` หรือ `bun run api:smoke:live` ผ่านกับ environment เป้าหมาย
CHAT_PROVIDER_LIVE_VERIFIED=0
CREATOR_DRAFT_RETRY_ATTEMPTS=3
CREATOR_DRAFT_RETRY_DELAY_MS=350
MAX_INPUT_CHARS=4000
MIN_TOKEN_BALANCE_FOR_CHAT=1

# ตัวเลือกเสริมสำหรับให้ Creator Studio สร้างรูป
# ถ้าไม่ตั้งค่า ระบบจะใช้ภาพตัวอย่างที่ติดป้ายชัดเจน แต่ AI ยังร่างเนื้อหาตัวละครได้
IMAGE_GENERATION_API_KEY=replace-with-openai-image-key
IMAGE_GENERATION_MODEL=gpt-image-1.5
IMAGE_GENERATION_SIZE=1024x1536
IMAGE_GENERATION_QUALITY=medium
IMAGE_GENERATION_OUTPUT_FORMAT=webp
IMAGE_GENERATION_OUTPUT_COMPRESSION=85
# ตั้งเป็น 1 เฉพาะหลัง `bun run smoke:image:live` หรือ `bun run api:smoke:live` ผ่านกับ environment เป้าหมาย
IMAGE_GENERATION_LIVE_VERIFIED=0

# ความปลอดภัย
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ADMIN_API_KEY=replace-with-long-random-admin-key

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
# ไม่บังคับ ถ้าเว้นว่างจะใช้ SUPABASE_URL/auth/v1
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
# ไม่บังคับ ใช้ตรวจ Supabase access token แบบ HS256/shared-secret ผ่าน Auth server
SUPABASE_ANON_KEY=replace-with-anon-key

# Supabase Storage
# ไม่บังคับสำหรับ local dev เมื่อตั้งสองค่านี้พร้อม SUPABASE_URL การอัปโหลด avatar จะใช้ Supabase Storage
STORAGE_PROVIDER=local
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=avatars
SUPABASE_STORAGE_ACCESS=signed
SUPABASE_SIGNED_URL_EXPIRES_IN=3600
